{
    "name": "tomshaw/laravel-dropbox",
    "description": "A Laravel Dropbox API client library.",
    "keywords": [
        "laravel",
        "dropbox"
    ],
    "homepage": "https://github.com/tomshaw/laravel-dropbox",
    "license": "MIT",
    "authors": [
        {
            "name": "Tom Shaw",
            "email": "tomshaw@users.noreply.github.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "illuminate/support": "^13.0",
        "laravel/framework": "^13.0",
        "guzzlehttp/guzzle": "^7.10"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.29",
        "nunomaduro/collision": "^8.9",
        "orchestra/testbench": "^11.1",
        "pestphp/pest": "^4.7"
    },
    "autoload": {
        "psr-4": {
            "TomShaw\\Dropbox\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TomShaw\\Dropbox\\Tests\\": "tests"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse --ansi --memory-limit=-1",
        "baseline": "vendor/bin/phpstan analyse --ansi --memory-limit=-1 --generate-baseline",
        "format": "vendor/bin/pint --config pint.json",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TomShaw\\Dropbox\\Providers\\DropboxServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
